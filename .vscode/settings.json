{
    "editor.fontSize": 16,
    "files.autoSave": "onFocusChange",
    "workbench.colorTheme": "Dark Modern",
    "terminal.integrated.initialHint": false,
    "terminal.integrated.accessibleViewPreserveCursorPosition": true,
    "terminal.integrated.accessibleViewFocusOnCommandExecution": true,
    "terminal.integrated.cursorStyle": "line",
    "workbench.startupEditor": "none",
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "accessibility.verbosity.debug": false,
    "accessibility.verbosity.inlineChat": false,
    "accessibility.verbosity.terminal": false,
    "python.terminal.shellIntegration.enabled": false,
    "accessibility.verbosity.sourceControl": false,
    "accessibility.verbosity.replEditor": false,
    "accessibility.verbosity.find": false,
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "testing.automaticallyOpenTestResults": "neverOpen",
    "debug.console.collapseIdenticalLines": false,
    "workbench.browser.showInTitleBar": false,
    "workbench.navigationControl.enabled": false,
    "git.confirmSync": false,
    "editor.formatOnSave": true,
    "editor.mouseWheelZoom": true,
    "editor.formatOnPaste": true,
    "editor.cursorBlinking": "smooth",
    "editor.find.addExtraSpaceOnTop": false,
    "editor.minimap.enabled": false,
    "editor.acceptSuggestionOnEnter": "off",
    "workbench.editor.autoLockGroups": {
        "mainThreadWebview-simpleBrowser.view": false
    },
    "chat.planAgent.defaultModel": "Auto (copilot)",
    "chat.restoreLastPanelSession": true,
    "chat.viewSessions.enabled": false,
    "merge-conflict.autoNavigateNextConflict.enabled": true,
    "python-envs.defaultEnvManager": "ms-python.python:conda",
    "python-envs.defaultPackageManager": "ms-python.python:conda"
}